{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug (gdb)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/Aquifer/build-cmake/appl/1p/H2/appl_1p2pnc_box_H2",
            "args": [],
