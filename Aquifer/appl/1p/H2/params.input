[TimeLoop]
DtInitial = 1000                   # [s] initial timestep size
TEnd = 24               # [d] simulation end time 
MaxTimeStepSize = 86400
[Grid]
LowerLeft = 0.2 0 
UpperRight = 1000.2 60        # [m] grid dimension
Cells = 200 20               # [-] number of cells in dimension

[Problem]
Name = H2 # name passed to the output routines
EnableGravity = true
UseNitscheTypeBc = true
DispersionMode = 0
InitialTemperature = 333.15

[BoundaryConditions]
Pressure_TOP = 60e5
CyclesDev = 1   		  # [-] number of cycles during development period
InjectionDurationDev = 8	  # [days] injection time during development period
IdleDurationDev = 0		  # [day] idle time during development period
InjectionDurationOp = 8	  # [day] injection time during operational period
ExtractionDurationOp = 8	  # [day] production time during operational period
IdleDurationOp = 0.0	  # [day] idle time during operational period
CushionGasType = CO2
InjectionRateDev = -25	  # [mol.m-2.s] injection rate during development period
InjectionRateOp = -25 # [mol.m-2.s] injection rate during operational period
ProductionRate = 25 # [mol.m-2.s] production rate during operational period
Well_Height = 10		  # [m] Height of the injection/withdrawal interval
HydrogenInjectionConcentration = 1
[Initialization]
PressureGWC = 60e5
DepthGWC = -10

[SpatialParams]
ReferencePorosity = 0.3
ReferencePermeability = 4.9346165e-13
Material.Swr = 0.26
Material.Snr = 0.0
Material.BrooksCoreyPcEntry = 5e3
Material.BrooksCoreyLambda = 2.0

[Newton]
MaxRelativeShift = 1e-6
MaxSteps = 6
MaxTimeStepDivisions = 20
UseLineSearch = true

[Assembly]
Multithreading = true 

[Vtk]
AddVelocity = true
